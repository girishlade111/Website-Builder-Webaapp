// Website Builder Platform - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  projects      Project[]
  collaborations Collaboration[]
  assets        Asset[]
  sessions      Session[]
  accounts      Account[]
  createdVersions ProjectVersion[]
  createdPageVersions PageVersion[]
  triggeredDeployments Deployment[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// PROJECT SYSTEM
// ============================================

model Project {
  id              String   @id @default(cuid())
  name            String
  description     String?
  slug            String   @unique
  thumbnail       String?
  status          ProjectStatus @default(DRAFT)
  
  // Settings
  settings        Json?    @default("{}") // SEO, domain, favicon, analytics
  
  // Deployment
  deploymentConfig Json?  @default("{}")
  deployedUrl     String?
  lastDeployedAt  DateTime?
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  pages           Page[]
  versions        ProjectVersion[]
  collaborations  Collaboration[]
  assets          Asset[]
  apiIntegrations ApiIntegration[]
  deployments     Deployment[]
  analytics       ProjectAnalytics[]

  // Template reference (if created from template)
  templateId      String?
  template        Template? @relation(fields: [templateId], references: [id])

  installedPlugins InstalledPlugin[]

  @@index([ownerId])
  @@index([slug])
  @@index([status])
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ============================================
// PAGE SYSTEM
// ============================================

model Page {
  id          String   @id @default(cuid())
  name        String
  slug        String
  path        String   // URL path like /, /about, /contact
  isHome      Boolean  @default(false)
  
  // Page content as JSON schema
  schema      Json     @default("{\"components\": []}")
  
  // SEO
  metaTitle   String?
  metaDescription String?
  metaKeywords String?
  ogImage     String?
  
  // Status
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  versions    PageVersion[]
  
  @@unique([projectId, path])
  @@index([projectId])
  @@index([slug])
}

// ============================================
// VERSION HISTORY
// ============================================

model ProjectVersion {
  id          String   @id @default(cuid())
  version     Int      @default(1)
  message     String?  // Commit message
  snapshot    Json     // Full project snapshot
  
  createdAt   DateTime @default(now())
  
  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  
  @@unique([projectId, version])
  @@index([projectId])
}

model PageVersion {
  id          String   @id @default(cuid())
  version     Int      @default(1)
  message     String?
  schema      Json     // Page schema snapshot
  
  createdAt   DateTime @default(now())
  
  // Relations
  pageId      String
  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  
  @@unique([pageId, version])
  @@index([pageId])
}

// ============================================
// COLLABORATION
// ============================================

model Collaboration {
  id          String   @id @default(cuid())
  role        CollaborationRole @default(EDITOR)
  invitedAt   DateTime @default(now())
  acceptedAt  DateTime?
  
  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@unique([userId, projectId])
  @@index([projectId])
}

enum CollaborationRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

// Real-time collaboration sessions (ephemeral, stored in Redis in production)
model CollaborationSession {
  id          String   @id @default(cuid())
  yjsState    Bytes?   // Yjs encoded state
  cursors     Json?    // User cursor positions
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  projectId   String   @unique
  
  @@index([projectId])
}

// ============================================
// ASSET MANAGEMENT
// ============================================

model Asset {
  id          String   @id @default(cuid())
  name        String
  type        AssetType
  url         String
  thumbnailUrl String?
  size        Int      // Size in bytes
  mimeType    String
  width       Int?     // For images/videos
  height      Int?     // For images/videos
  
  // Storage provider info
  storageProvider String @default("local") // local, s3, cloudinary
  storageKey  String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  uploadedById String?
  uploadedBy  User?    @relation(fields: [uploadedById], references: [id])
  
  @@index([projectId])
  @@index([type])
}

enum AssetType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  FONT
  OTHER
}

// ============================================
// TEMPLATE SYSTEM
// ============================================

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  thumbnail   String?
  category    String?
  tags        String[] @default([])

  // Template schema (predefined pages structure)
  schema      Json     @default("{\"pages\": []}")

  // Publishing
  isPublished Boolean  @default(true)

  // Pricing
  isPremium   Boolean  @default(false)
  price       Decimal? @default(0)

  // Stats
  installs    Int      @default(0)
  rating      Float    @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  projects    Project[]

  @@index([category])
  @@index([tags])
}

// ============================================
// PLUGIN & EXTENSION MARKETPLACE
// ============================================

model Plugin {
  id          String   @id @default(cuid())
  name        String
  description String?
  version     String   @default("1.0.0")
  type        PluginType
  
  // Plugin content
  manifest    Json     // Plugin configuration
  code        String?  // Plugin code (for code plugins)
  schema      Json?    // Component schema (for component plugins)
  
  // Marketplace
  isPublished Boolean  @default(false)
  isPremium   Boolean  @default(false)
  price       Decimal? @default(0)
  
  // Stats
  installs    Int      @default(0)
  rating      Float    @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  projects    InstalledPlugin[]
  
  @@index([type])
  @@index([isPublished])
}

enum PluginType {
  COMPONENT
  FEATURE
  INTEGRATION
  THEME
  ANALYTICS
}

model InstalledPlugin {
  id          String   @id @default(cuid())
  settings    Json?    // Plugin-specific settings
  
  installedAt DateTime @default(now())
  
  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  pluginId    String
  plugin      Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  
  @@unique([projectId, pluginId])
}

// ============================================
// API INTEGRATIONS
// ============================================

model ApiIntegration {
  id          String   @id @default(cuid())
  name        String
  description String?
  
  // API config
  endpoint    String
  method      HttpMethod @default(GET)
  headers     Json?      @default("{}")
  
  // Auth
  authType    ApiAuthType?
  authConfig  Json?      // Encrypted auth config
  
  // Response mapping
  responseMapping Json?  // How to map API response to components
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

enum ApiAuthType {
  NONE
  API_KEY
  OAUTH2
  BEARER
  BASIC
}

// ============================================
// DEPLOYMENT
// ============================================

model Deployment {
  id          String   @id @default(cuid())
  status      DeploymentStatus @default(PENDING)
  environment DeploymentEnvironment @default(PRODUCTION)
  
  // Vercel specific
  vercelId    String?
  vercelUrl   String?
  vercelError String?
  
  // Build info
  buildLog    String?
  buildOutput Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  triggeredById String?
  triggeredBy   User?  @relation(fields: [triggeredById], references: [id])
  
  @@index([projectId])
  @@index([status])
}

enum DeploymentStatus {
  PENDING
  BUILDING
  DEPLOYING
  SUCCESS
  FAILED
  CANCELLED
}

enum DeploymentEnvironment {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

// ============================================
// ANALYTICS & METRICS
// ============================================

model ProjectAnalytics {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  
  // Metrics
  views       Int      @default(0)
  uniqueVisitors Int   @default(0)
  bounceRate  Float    @default(0)
  avgSessionDuration Int @default(0) // seconds
  
  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@unique([projectId, date])
  @@index([projectId])
}
